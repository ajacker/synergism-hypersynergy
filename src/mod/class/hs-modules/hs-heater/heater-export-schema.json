        "lifeTimeRedAmbrosia": { "type": "number" },
        "quarks": { "type": "number" },
        "platonic4x4": { "type": "number" },
        "baseLuck": { "type": "number" },
        "luckMult": { "type": "number" },
        "totalLuck": { "type": "number" },
        "trueBaseLuck": { "type": "number" },
        "redAmbrosiaLuck": { "type": "number" },
        "luckConversion": { "type": "number" },
        "totalCubes": { "type": "number" },
        "effectiveSingularity": { "type": "number" },
        "transcription": { "type": "number" },
        "ascSpeed": { "type": "number" },
        "ascSpeed2": { "type": "number" },
        "sirc": { "type": "number" },
        "bonussi": { "type": "number" },
