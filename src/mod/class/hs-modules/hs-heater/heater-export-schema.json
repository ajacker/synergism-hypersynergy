            "redAmbrosiaCubeImprover",
            "viscount",
            "infiniteShopUpgrades",
            "redAmbrosiaAccelerator",
            "salvageYinYang",
            "blueberries"
          ],
          "properties": {
            "tutorial": { "type": "number" },
            "conversionImprovement1": { "type": "number" },
            "conversionImprovement2": { "type": "number" },
            "conversionImprovement3": { "type": "number" },
            "freeTutorialLevels": { "type": "number" },
            "freeLevelsRow2": { "type": "number" },
            "freeLevelsRow3": { "type": "number" },
            "freeLevelsRow4": { "type": "number" },
            "freeLevelsRow5": { "type": "number" },
            "blueberryGenerationSpeed": { "type": "number" },
            "blueberryGenerationSpeed2": { "type": "number" },
            "regularLuck": { "type": "number" },
            "regularLuck2": { "type": "number" },
            "redGenerationSpeed": { "type": "number" },
